{
  "name": "mongodb-ram-observatory",
  "version": "1.0.0",
  "description": "MongoDB RAM Pool Observatory & Sizing Calculator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "npm run build && node server/index.js",
    "seed": "node scripts/seed-data.js",
    "verify-seed": "node scripts/verify-seed.js",
    "cleanup": "node scripts/cleanup.js",
    "verify-cleanup": "node scripts/verify-cleanup.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
